{
  "name": "the-legendary-poet",
  "private": true,
  "version": "1.0.0",
  "description": "Dark luxury editorial site about great Russian poets",
  "type": "module",
  "license": "MIT",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "typecheck": "tsc --noEmit",
    "sitemap": "node scripts/gen-sitemap.mjs",
    "check:integrity": "npx tsx scripts/check-integrity.ts",
    "check": "npm run typecheck && npm run check:integrity && npm run check:library && npm run check:deep && npm run build && node scripts/postbuild.mjs && npm run check:smoke",
    "check:deep": "npx tsx scripts/check-deep.ts",
    "check:smoke": "node scripts/check-smoke.mjs",
    "test:hall": "npx playwright test e2e/hall.spec.ts",
    "check:hall": "node scripts/check-hall.mjs",
    "check:library": "npx tsx scripts/validate-library.ts"
  },
  "dependencies": {
    "@react-three/drei": "^10.7.7",
    "@react-three/fiber": "^9.6.1",
    "@react-three/postprocessing": "^3.0.4",
    "@types/three": "^0.184.0",
    "clsx": "^2.1.1",
    "framer-motion": "^12.38.0",
    "lenis": "^1.3.23",
    "postprocessing": "^6.39.2",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "react-router-dom": "^7.18.1",
    "tailwind-merge": "^3.4.0",
    "three": "^0.184.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.1",
    "@tailwindcss/vite": "4.1.17",
    "@types/node": "22.19.17",
    "@types/react": "19.2.7",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react": "5.1.1",
    "tailwindcss": "4.1.17",
    "tsx": "^4.23.1",
    "typescript": "5.9.3",
    "vite": "^7.3.6"
  }
}
