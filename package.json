{
  "name": "react-vite-tailwind",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "typecheck": "tsc --noEmit",
    "validate:library": "tsx scripts/validate-library.ts",
    "validate:essays": "tsx scripts/validate-essays.ts",
    "report:sources": "tsx scripts/report-essay-source-coverage.ts",
    "validate:citations": "tsx scripts/validate-citations.ts",
    "validate:clusters": "tsx scripts/validate-topic-clusters.ts",
    "validate:mayakovsky-correspondence": "tsx scripts/validate-mayakovsky-correspondence-index.ts",
    "validate:yesenin-archive": "tsx scripts/validate-yesenin-archive.ts",
    "validate:yesenin-part-one": "tsx scripts/validate-yesenin-part-one-research.ts",
    "validate:yesenin-part-one-witnesses": "tsx scripts/validate-yesenin-part-one-page-witnesses.ts",
    "validate:public-claims": "tsx scripts/validate-public-claims.ts",
    "validate:audio": "tsx scripts/validate-audio-assets.ts",
    "validate:audio:available": "tsx scripts/validate-audio-assets.ts --allow-missing",
    "validate:music": "tsx scripts/validate-music-catalog.ts",
    "validate:music-runtime": "tsx scripts/validate-music-runtime.ts",
    "validate:audio-session": "tsx scripts/validate-audio-session-store.ts",
    "validate:archive-store": "tsx scripts/validate-personal-archive-store.ts",
    "validate:community-store": "tsx scripts/validate-community-store.ts",
    "validate:community-target-store": "tsx scripts/validate-community-target-store.ts",
    "validate:app-shell": "tsx scripts/validate-app-shell.ts",
    "validate:interaction-runtime": "tsx scripts/validate-interaction-runtime.ts",
    "validate:build-output": "tsx scripts/validate-build-output.ts",
    "validate:style": "tsx scripts/validate-literary-style.ts",
    "validate:prerender-seo": "tsx scripts/validate-prerendered-seo.ts && tsx scripts/validate-top-level-prerender.ts",
    "validate:route-chunks": "tsx scripts/validate-route-chunks.ts",
    "validate:media": "tsx scripts/validate-essay-media.ts",
    "check": "npm run validate:library && npm run validate:essays && npm run report:sources && npm run validate:citations && npm run validate:clusters && npm run validate:mayakovsky-correspondence && npm run validate:yesenin-archive && npm run validate:yesenin-part-one && npm run validate:yesenin-part-one-witnesses && npm run validate:public-claims && npm run validate:media && npm run validate:audio:available && npm run validate:music && npm run validate:music-runtime && npm run validate:audio-session && npm run validate:archive-store && npm run validate:community-store && npm run validate:community-target-store && npm run validate:app-shell && npm run validate:interaction-runtime && npm run validate:style && npm run typecheck",
    "sitemap": "node scripts/gen-sitemap.mjs",
    "prerender": "tsx scripts/prerender-og.mjs && node scripts/prerender-404.mjs",
    "images:sync": "node scripts/localize-essay-images.mjs",
    "test:e2e": "node scripts/run-playwright-ci.mjs"
  },
  "dependencies": {
    "@react-three/drei": "^10.7.7",
    "@react-three/fiber": "^9.6.1",
    "@react-three/postprocessing": "^3.0.4",
    "@studio-freight/lenis": "^1.0.42",
    "@types/three": "^0.184.0",
    "clsx": "^2.1.1",
    "framer-motion": "^12.38.0",
    "lenis": "^1.3.23",
    "lucide-react": "^1.12.0",
    "postprocessing": "^6.39.2",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "react-router-dom": "^7.14.2",
    "tailwind-merge": "^3.4.0",
    "three": "^0.184.0"
  },
  "devDependencies": {
    "@tailwindcss/vite": "4.1.17",
    "@types/node": "22.19.17",
    "@types/react": "19.2.7",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react": "5.1.1",
    "tailwindcss": "4.1.17",
    "tsx": "^4.23.1",
    "typescript": "5.9.3",
    "vite": "7.2.4",
    "vite-plugin-singlefile": "2.3.0"
  }
}
